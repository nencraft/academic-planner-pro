<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="AcademicPlanner.Views.CourseEditPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    BackgroundColor="#EFEFEF"
    Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,Auto,*">

        <Grid
            Grid.Row="0"
            Padding="16,12,16,8"
            BackgroundColor="White"
            ColumnDefinitions="56,*,56"
            ColumnSpacing="16">

            <ImageButton
                Grid.Column="0"
                Padding="0"
                Aspect="AspectFit"
                BackgroundColor="Transparent"
                Clicked="OnBackClicked"
                HeightRequest="48"
                HorizontalOptions="Center"
                Source="icon_back.png"
                VerticalOptions="Center"
                WidthRequest="48" />

            <ImageButton
                Grid.Column="1"
                Padding="0"
                Aspect="AspectFit"
                BackgroundColor="Transparent"
                Clicked="OnHomeClicked"
                HeightRequest="56"
                HorizontalOptions="Center"
                Source="wgu_owl.png"
                VerticalOptions="Center"
                WidthRequest="56" />


        </Grid>

        <Border
            Grid.Row="1"
            Padding="0,10"
            BackgroundColor="#002f51"
            StrokeThickness="0">
            <Label
                x:Name="BannerTitleLabel"
                FontAttributes="Bold"
                FontSize="22"
                HorizontalOptions="Center"
                Text="Add Course"
                TextColor="White"
                VerticalOptions="Center" />
        </Border>

        <ScrollView Grid.Row="2">
            <VerticalStackLayout Padding="28,36,28,40" Spacing="22">

                <Grid
                    ColumnDefinitions="Auto,*"
                    ColumnSpacing="12"
                    RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto"
                    RowSpacing="12">

                    <Label
                        Grid.Row="0"
                        Grid.Column="0"
                        FontSize="20"
                        HorizontalTextAlignment="End"
                        Text="Course Title:"
                        VerticalTextAlignment="Center" />

                    <Border
                        Grid.Row="0"
                        Grid.Column="1"
                        BackgroundColor="#F5F5F5"
                        HeightRequest="54"
                        Stroke="Black"
                        StrokeThickness="1">
                        <Entry
                            x:Name="TitleEntry"
                            BackgroundColor="Transparent"
                            ClearButtonVisibility="WhileEditing"
                            FontSize="18"
                            Placeholder="{StaticResource TitlePlaceholder}" />
                    </Border>

                    <Label
                        Grid.Row="1"
                        Grid.Column="0"
                        FontSize="20"
                        HorizontalTextAlignment="End"
                        Text="StartDate:"
                        VerticalTextAlignment="Center" />

                    <Border
                        Grid.Row="1"
                        Grid.Column="1"
                        BackgroundColor="#F5F5F5"
                        HeightRequest="54"
                        Stroke="Black"
                        StrokeThickness="1">
                        <DatePicker
                            x:Name="StartDatePicker"
                            BackgroundColor="Transparent"
                            FontSize="18"
                            Format="MM/dd/yyyy" />
                    </Border>

                    <Label
                        Grid.Row="2"
                        Grid.Column="0"
                        FontSize="20"
                        HorizontalTextAlignment="End"
                        Text="EndDate:"
                        VerticalTextAlignment="Center" />

                    <Border
                        Grid.Row="2"
                        Grid.Column="1"
                        BackgroundColor="#F5F5F5"
                        HeightRequest="54"
                        Stroke="Black"
                        StrokeThickness="1">
                        <DatePicker
                            x:Name="EndDatePicker"
                            BackgroundColor="Transparent"
                            FontSize="18"
                            Format="MM/dd/yyyy" />
                    </Border>

                    <Label
                        Grid.Row="3"
                        Grid.Column="0"
                        FontSize="20"
                        HorizontalTextAlignment="End"
                        Text="Status:"
                        VerticalTextAlignment="Center" />

                    <Border
                        Grid.Row="3"
                        Grid.Column="1"
                        BackgroundColor="#F5F5F5"
                        HeightRequest="54"
                        Stroke="Black"
                        StrokeThickness="1">
                        <Picker
                            x:Name="StatusPicker"
                            Title="Select status"
                            BackgroundColor="Transparent"
                            FontSize="18" />
                    </Border>

                    <Label
                        Grid.Row="4"
                        Grid.Column="0"
                        FontSize="20"
                        HorizontalTextAlignment="End"
                        Text="Instructor Name:"
                        VerticalTextAlignment="Center" />

                    <Border
                        Grid.Row="4"
                        Grid.Column="1"
                        BackgroundColor="#F5F5F5"
                        HeightRequest="54"
                        Stroke="Black"
                        StrokeThickness="1">
                        <Entry
                            x:Name="InstructorNameEntry"
                            BackgroundColor="Transparent"
                            FontSize="18"
                            Placeholder="{StaticResource InstructorNamePlaceholder}" />
                    </Border>

                    <Label
                        Grid.Row="5"
                        Grid.Column="0"
                        FontSize="20"
                        HorizontalTextAlignment="End"
                        Text="Instructor Phone:"
                        VerticalTextAlignment="Center" />

                    <Border
                        Grid.Row="5"
                        Grid.Column="1"
                        BackgroundColor="#F5F5F5"
                        HeightRequest="54"
                        Stroke="Black"
                        StrokeThickness="1">
                        <Entry
                            x:Name="InstructorPhoneEntry"
                            BackgroundColor="Transparent"
                            FontSize="18"
                            Keyboard="Telephone"
                            Placeholder="{StaticResource PhonePlaceholder}" />
                    </Border>

                    <Label
                        Grid.Row="6"
                        Grid.Column="0"
                        FontSize="20"
                        HorizontalTextAlignment="End"
                        Text="Instructor Email:"
                        VerticalTextAlignment="Center" />

                    <Border
                        Grid.Row="6"
                        Grid.Column="1"
                        BackgroundColor="#F5F5F5"
                        HeightRequest="54"
                        Stroke="Black"
                        StrokeThickness="1">
                        <Entry
                            x:Name="InstructorEmailEntry"
                            BackgroundColor="Transparent"
                            FontSize="18"
                            Keyboard="Email"
                            Placeholder="{StaticResource EmailPlaceholder}" />
                    </Border>

                    <Label
                        Grid.Row="7"
                        Grid.Column="0"
                        FontSize="20"
                        HorizontalTextAlignment="End"
                        Text="Notes:"
                        VerticalTextAlignment="Start" />

                    <Border
                        Grid.Row="7"
                        Grid.Column="1"
                        Padding="6"
                        BackgroundColor="#F5F5F5"
                        MinimumHeightRequest="110"
                        Stroke="Black"
                        StrokeThickness="1">
                        <Editor
                            x:Name="NotesEditor"
                            AutoSize="TextChanges"
                            BackgroundColor="Transparent"
                            FontSize="18" />
                    </Border>


                    <Label
                        Grid.Row="8"
                        Grid.Column="0"
                        FontSize="20"
                        HorizontalTextAlignment="End"
                        Text="Set Alert:"
                        VerticalTextAlignment="Center" />

                    <Border
                        Grid.Row="8"
                        Grid.Column="1"
                        BackgroundColor="#F5F5F5"
                        HeightRequest="54"
                        Stroke="Black"
                        StrokeThickness="1">
                        <Picker
                            x:Name="AlertSettingPicker"
                            Title="Select alert setting"
                            BackgroundColor="Transparent"
                            FontSize="18" />
                    </Border>
                </Grid>

                <Grid
                    Margin="0,24,0,0"
                    ColumnDefinitions="*,*"
                    ColumnSpacing="16"
                    HorizontalOptions="Fill">

                    <Button
                        Grid.Column="0"
                        Padding="12,0"
                        BackgroundColor="#F5F5F5"
                        BorderColor="Black"
                        BorderWidth="1"
                        Clicked="OnSaveClicked"
                        CornerRadius="16"
                        FontSize="16"
                        HeightRequest="58"
                        HorizontalOptions="Fill"
                        ImageSource="icon_save.png"
                        Text="Save Course"
                        TextColor="Black" />

                    <Button
                        Grid.Column="1"
                        Padding="12,0"
                        BackgroundColor="#F5F5F5"
                        BorderColor="Black"
                        BorderWidth="1"
                        Clicked="OnCancelClicked"
                        CornerRadius="16"
                        FontSize="16"
                        HeightRequest="58"
                        HorizontalOptions="Fill"
                        ImageSource="icon_cancel.png"
                        Text="Cancel"
                        TextColor="Black" />
                </Grid>


            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>