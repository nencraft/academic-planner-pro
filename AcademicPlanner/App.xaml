<?xml version="1.0" encoding="UTF-8" ?>
<Application
    x:Class="AcademicPlanner.App"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">
    <Application.Resources>
        <ResourceDictionary>
            <x:String x:Key="NamePlaceholder">Enter name</x:String>
            <x:String x:Key="InstructorNamePlaceholder">Enter instructor name</x:String>
            <x:String x:Key="EmailPlaceholder">example@address.com</x:String>
            <x:String x:Key="PhonePlaceholder">xxx-xxx-xxxx</x:String>
            <x:String x:Key="TitlePlaceholder">Enter title</x:String>
            <x:String x:Key="NotesPlaceholder">Enter notes</x:String>
        </ResourceDictionary>
    </Application.Resources>
</Application>