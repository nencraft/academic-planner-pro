<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="AcademicPlanner.Views.TermsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:models="clr-namespace:AcademicPlanner.Models"
    BackgroundColor="#EFEFEF"
    Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,Auto,*">

        <Grid
            Padding="16,12,16,8"
            BackgroundColor="White"
            ColumnDefinitions="56,*,56"
            ColumnSpacing="16">

            <ImageButton
                Grid.Column="1"
                Padding="0"
                Aspect="AspectFit"
                BackgroundColor="Transparent"
                Clicked="OnHomeClicked"
                HeightRequest="56"
                HorizontalOptions="Center"
                Source="wgu_owl.png"
                VerticalOptions="Center"
                WidthRequest="56" />

            <ImageButton
                Grid.Column="0"
                Aspect="AspectFit"
                Padding="0"
                BackgroundColor="Transparent"
                Clicked="OnSettingsClicked"
                HeightRequest="48"
                HorizontalOptions="Center"
                Source="icon_settings.png"
                VerticalOptions="Center"
                WidthRequest="48" />

            <ImageButton
                Grid.Column="2"
                Margin="0"
                Padding="0"
                Aspect="AspectFit"
                BackgroundColor="Transparent"
                Clicked="OnAddTermClicked"
                HeightRequest="48"
                HorizontalOptions="Center"
                Source="icon_add.png"
                VerticalOptions="Center"
                WidthRequest="48" />
        </Grid>

        <Border
            Grid.Row="1"
            Padding="0,10"
            BackgroundColor="#002f51"
            StrokeThickness="0">
            <Label
                FontSize="22"
                HorizontalOptions="Center"
                Text="WGU Academic Planner"
                TextColor="White"
                VerticalOptions="Center"
                FontAttributes="Bold"/>
        </Border>

        <CollectionView
            x:Name="TermsCollectionView"
            Grid.Row="2"
            Margin="0,24,0,0"
            SelectionMode="None">

            <CollectionView.EmptyView>
                <VerticalStackLayout Padding="24,32" Spacing="12">
                    <Label
                        FontSize="24"
                        HorizontalOptions="Center"
                        Text="No terms yet" />
                    <Label
                        FontSize="16"
                        HorizontalOptions="Center"
                        Text="Tap the plus icon to add your first term." />
                </VerticalStackLayout>
            </CollectionView.EmptyView>

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:Term">
                    <Grid Padding="0,16">
                        <Border
                            Padding="18"
                            BackgroundColor="#F5F5F5"
                            HorizontalOptions="Center"
                            StrokeThickness="0"
                            WidthRequest="480">
                            <Border.Shadow>
                                <Shadow
                                    Brush="#33000000"
                                    Opacity="1"
                                    Radius="10"
                                    Offset="0,4" />
                            </Border.Shadow>

                            <Grid ColumnDefinitions="*,70" VerticalOptions="Center">

                                <VerticalStackLayout
                                    Grid.Column="0"
                                    HorizontalOptions="Center"
                                    Spacing="6"
                                    VerticalOptions="Center">
                                    <Label
                                        FontAttributes="Bold"
                                        FontSize="28"
                                        HorizontalTextAlignment="Center"
                                        Text="{Binding DisplayTitle}"
                                        TextColor="Black" />

                                    <Label
                                        FontSize="16"
                                        HorizontalTextAlignment="Center"
                                        TextColor="Black">
                                        <Label.FormattedText>
                                            <FormattedString>
                                                <Span Text="{Binding StartDate, StringFormat='{0:MM/dd/yyyy}'}" />
                                                <Span Text=" - " />
                                                <Span Text="{Binding EndDate, StringFormat='{0:MM/dd/yyyy}'}" />
                                            </FormattedString>
                                        </Label.FormattedText>
                                    </Label>
                                </VerticalStackLayout>

                                <ImageButton
                                    Grid.Column="1"
                                    Aspect="AspectFit"
                                    BackgroundColor="Transparent"
                                    Clicked="OnTermSelectedClicked"
                                    CommandParameter="{Binding Id}"
                                    HeightRequest="56"
                                    HorizontalOptions="Center"
                                    Source="icon_expand.png"
                                    TranslationX="-15"
                                    VerticalOptions="Center"
                                    WidthRequest="56" />

                            </Grid>
                        </Border>
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </Grid>
</ContentPage>