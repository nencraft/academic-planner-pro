<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="AcademicPlanner.Views.PinUnlockPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Unlock">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="16">
            <Label
                FontAttributes="Bold"
                FontSize="28"
                Text="Unlock Academic Planner" />

            <Label FontSize="16" Text="Enter your PIN to continue." />

            <Entry
                x:Name="PinEntry"
                IsPassword="True"
                Keyboard="Numeric"
                MaxLength="4"
                Placeholder="4-digit PIN" />

            <Button
                Margin="0,12,0,0"
                BackgroundColor="#F5F5F5"
                BorderColor="Black"
                BorderWidth="2"
                Clicked="OnUnlockClicked"
                CornerRadius="16"
                FontSize="16"
                HeightRequest="58"
                ImageSource="icon_unlock.png"
                Text="Unlock"
                TextColor="Black" />

            <Button
                Margin="0,12,0,0"
                BackgroundColor="#F5F5F5"
                BorderColor="Black"
                BorderWidth="2"
                Clicked="OnUsePasswordClicked"
                CornerRadius="16"
                FontSize="16"
                HeightRequest="58"
                ImageSource="icon_password.png"
                Text="Use Password Instead"
                TextColor="Black" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>